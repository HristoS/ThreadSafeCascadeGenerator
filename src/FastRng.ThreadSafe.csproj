<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>FastRng.ThreadSafe</PackageId>
    <Version>1.0.0</Version>
    <Authors>Hristo Stoew</Authors>
    <Description>Highperformance cascade RNG generator, bases on 6-layers dinamick permutations for .NET 10 </Description>
    <PackageTags>random;rng;threadsafe;high-performance;cryptography;rc4;avalanche-effect;l1-cache;chi-squared;math;simulation</PackageTags>
    <RepositoryUrl>https://github.com/HristoS/ThreadSafeCascadeGenerator</RepositoryUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>
</Project>